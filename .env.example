# ============================================
# 500Claw Platform — Environment Variables
# ============================================
# Copy to .env.local and fill in your values:
#   cp .env.example .env.local

# ------- Supabase -------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------- OpenClaw Gateway -------
# WebSocket AI chat engine — connect via Tailscale private network
# Use the Tailscale IP of the server running OpenClaw (100.x.x.x)
OPENCLAW_GATEWAY_HOST=100.x.x.x
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_TOKEN=your-gateway-token

# ------- Application -------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------- Encryption -------
# Used for credential vault (API keys, OAuth tokens) and signed URLs
# Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=

# ------- OAuth Providers -------
# App-level OAuth credentials (NOT per-user — these identify your app to GitHub/Google)
# Users connect their own accounts via OAuth flow using these app credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------- AI / LLM -------
# Google Gemini for report generation and email template AI
GEMINI_API_KEY=

# Knowledge layer LLM (Vercel AI SDK). Fireworks API key for the default models.
FIREWORKS_API_KEY=
# Model id for the knowledge layer. Fireworks account paths use FIREWORKS_API_KEY;
# any other "provider/model" string routes through the Vercel AI Gateway.
#   Kimi K2.5:     accounts/fireworks/models/kimi-k2p5   (default)
#   DeepSeek V3.2: accounts/fireworks/models/deepseek-v3p2
KNOWLEDGE_MODEL=accounts/fireworks/models/kimi-k2p5

# ------- Email (Resend) -------
# Webhook secret for verifying Resend event signatures (svix)
# Found in Resend dashboard → Webhooks → Signing Secret
RESEND_WEBHOOK_SECRET=

# ------- Cron -------
# Secret for authenticating scheduled campaign processing endpoint
# Falls back to CREDENTIAL_ENCRYPTION_KEY if not set
CRON_SECRET=
